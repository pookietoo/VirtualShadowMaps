# ---- Build output ----
plugin/build/
build/
*.obj
*.pdb
*.ilk

# ---- Vendored dependencies (large, reproducible via cmake/vcpkg) ----
extern/
community-shaders/

# ---- Local mod folder / build output (NEVER published; shader SOURCE lives in /Shaders) ----
dist/

# ---- Dev screenshots (not part of the project) ----
screenshots/

# ---- Logs (runtime dumps + binary sidecars: atlas/id/geom .bin, captured textures) — NEVER published ----
*.log
logs/

# ---- Local dev/analysis tooling (offline shadow verifier) — not needed to compile or use the mod ----
tools/

# ---- Local design/roadmap notes (kept locally, not part of the shipped project) ----
notes/

# ---- Local speed-testing harness (mirror benchmarks, PLAN.md) — not part of the shipped project ----
testing/

# ---- Detailed local documentation (deep architecture write-up) — not part of the shipped project ----
docs/

# ---- Diagnostics apparatus (dev-only; VSM_DIAGNOSTICS, compiled OUT of the deployment build and excluded
# ---- from CMake sources in a deploy build). Kept LOCAL for dev builds (-DVSM_DEV_BUILD=ON); NOT shipped. ----
plugin/src/VirtualShadowMaps_Diagnostics.cpp
plugin/src/VirtualShadowMaps_Diagnostics.h

# ---- Holding area for removed code (user empties this) ----
trash/

# ---- OS / editor ----
.vs/
*.user
Thumbs.db
desktop.ini
